# Jitsi Meet Configuration
# Self-hosted with Transcription & Translation

# ==============================================================================
# Basic Configuration
# ==============================================================================
COMPOSE_PROJECT_NAME=jitsi

# Public URL - CHANGE THIS TO YOUR DOMAIN
PUBLIC_URL=https://meet.yourdomain.com

# Jitsi image version (stable is recommended)
JITSI_IMAGE_VERSION=stable

# System timezone
TZ=UTC

# ==============================================================================
# HTTP/HTTPS Configuration
# ==============================================================================
# Enable HTTP (for initial setup/testing)
# For production, use reverse proxy with HTTPS
HTTP_PORT=8000
HTTPS_PORT=8443

# ==============================================================================
# Authentication
# ==============================================================================
# Enable authentication (recommended for production)
# ENABLE_AUTH=1

# Enable guest access (optional)
# ENABLE_GUESTS=1

# ==============================================================================
# Transcription & Translation - REQUIRED for transcription feature
# ==============================================================================
# Enable transcriptions across all services
ENABLE_TRANSCRIPTIONS=1

# Disable SIP gateway (we're using transcriber mode)
ENABLE_SIP=false

# Transcriber configuration
JIGASI_MODE=transcriber

# Transcriber XMPP credentials - CHANGE THESE
JIGASI_TRANSCRIBER_USER=transcriber@recorder.yourdomain.com
JIGASI_TRANSCRIBER_PASSWORD=change_this_password

# Save transcripts to files
JIGASI_TRANSCRIBER_ENABLE_SAVING=true

# Enable translation (uses LibreTranslate by default when using Vosk)
JIGASI_TRANSCRIBER_ENABLE_TRANSLATION=1

# LibreTranslate URL (free, self-hosted translation)
JIGASI_TRANSCRIBER_LIBRETRANSLATE_URL=http://libretranslate:5000

# Alternative: Use Google Translate (NOT FREE)
# To use Google Translate instead of LibreTranslate:
# 1. Comment out JIGASI_TRANSCRIBER_LIBRETRANSLATE_URL above
# 2. Uncomment and fill in GC_* credentials in the Google Cloud section
# 3. Remove JIGASI_TRANSCRIBER_CUSTOM_SERVICE (use default Google STT)

# ==============================================================================
# Transcription Service - CHOOSE ONE
# ==============================================================================

# Option 1: Vosk (Recommended - Free, Open Source, Self-hosted)
# Requires running the Vosk container separately
JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.VoskTranscriptionService
JIGASI_TRANSCRIBER_VOSK_URL=ws://vosk:2700

# Option 2: Whisper (OpenAI - Free, Open Source, Self-hosted)
# Uncomment below and comment out Vosk to use Whisper instead
# JIGASI_TRANSCRIBER_CUSTOM_SERVICE=org.jitsi.jigasi.transcription.WhisperTranscriptionService
# JIGASI_TRANSCRIBER_WHISPER_URL=http://whisper:8000

# Option 3: Google Cloud (NOT FREE - requires GCP credentials)
# Uncomment and add GC_* credentials below to use Google Cloud
# JIGASI_TRANSCRIBER_CUSTOM_SERVICE=

# ==============================================================================
# Google Cloud Configuration (Only if using Google Cloud)
# ==============================================================================
# Only fill these in if you're using Option 3 above
# GC_PROJECT_ID=your-gcp-project-id
# GC_PRIVATE_KEY_ID=your-private-key-id
# GC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
# GC_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GC_CLIENT_ID=your-client-id
# GC_CLIENT_CERT_URL=https://storage.googleapis.com/your-bucket/key.json

# ==============================================================================
# Translation Languages
# ==============================================================================
# Languages available in the UI
TRANSLATION_LANGUAGES=["en","es","de","fr","it","pt","ru","zh","ja","ko","ar"]

# Default language
PREFERRED_LANGUAGE=en

# ==============================================================================
# XMPP Server Configuration
# ==============================================================================
XMPP_DOMAIN=yourdomain.com
XMPP_AUTH_DOMAIN=auth.yourdomain.com
XMPP_GUEST_DOMAIN=guest.yourdomain.com
XMPP_MUC_DOMAIN=muc.yourdomain.com
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.yourdomain.com
XMPP_RECORDER_DOMAIN=recorder.yourdomain.com
XMPP_HIDDEN_DOMAIN=hidden.yourdomain.com

# ==============================================================================
# Docker Network
# ==============================================================================
# Network name - default is meet.jitsi, don't change this
DOCKER_HOST_ADDRESS=auto